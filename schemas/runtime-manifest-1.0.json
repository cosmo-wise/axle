{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Axle Runtime Manifest",
  "type": "object",
  "required": ["appName", "version", "resources"],
  "properties": {
    "appName": { "type": "string" },
    "version": { "type": "string" },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "route": { "type": "string" },
          "methods": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "database": {
      "type": "object",
      "properties": {
        "engine": { "type": "string" },
        "migrationCount": { "type": "integer" }
      }
    },
    "generatedAt": { "type": "string", "format": "date-time" }
  }
}
