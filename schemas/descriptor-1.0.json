{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Axle Descriptor Schema",
  "description": "Versioned schema for axle resource descriptors",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "type": "string" },
    "kind": { "type": "string", "enum": ["Resource", "Model", "Enum"] },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "spec": { "type": "object" }
  }
}
