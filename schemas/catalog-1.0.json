{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Axle Catalog Manifest",
  "type": "object",
  "required": ["apiVersion", "resources"],
  "properties": {
    "apiVersion": { "type": "string" },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "metadata"],
        "properties": {
          "kind": { "type": "string" },
          "metadata": {
            "type": "object",
            "properties": {
              "name": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
